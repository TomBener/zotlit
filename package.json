{
  "name": "zotlit",
  "version": "0.4.2",
  "description": "Zotero literature search CLI for AI agents",
  "type": "module",
  "bin": {
    "zotlit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "prepack": "npm run build",
    "dev": "tsx src/cli.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "check": "npm run lint && npm test"
  },
  "dependencies": {
    "@opendataloader/pdf": "^2.2.1",
    "@pngwasi/node-tantivy-binding": "^0.3.4",
    "@tobilu/qmd": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
